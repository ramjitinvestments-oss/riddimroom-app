rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ---------------------------------------------------------
    // GLOBALS & HELPERS
    // ---------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.get('email_verified', false) == true; }
    function isSelf(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.get('email', '') == 'RamjitInvestments@gmail.com' ||
        request.auth.token.get('email', '') == 'ramjitinvestments@gmail.com' ||
        request.auth.token.get('email', '') == 'RamjitInvestments@google.com' ||
        request.auth.token.get('email', '') == 'ramjitinvestments@google.com'
      ); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { return id is string && id.size() >= 1; }
    
    // User status must be APPROVED for standard app logic
    function isApproved() {
      return isAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'APPROVED'
      );
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // USERS COLLECTION
    // ---------------------------------------------------------
    match /users/{userId} {
      allow read: if isSelf(userId) || isAdmin();
      allow create: if isSelf(userId) && (
        isAdmin() || (
          incoming().role == 'USER' && 
          incoming().status == 'PENDING'
        )
      );
      allow update: if isSelf(userId) && (
        isAdmin() || (
          (!incoming().keys().hasAll(['role']) || incoming().role == existing().role) &&
          (!incoming().keys().hasAll(['status']) || incoming().status == existing().status)
        )
      );
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------
    // ADMINS COLLECTION
    // ---------------------------------------------------------
    match /admins/{userId} {
      allow read: if isAdmin();
      allow write: if false; // Managed via Firebase Console or manual admin action
    }

    // ---------------------------------------------------------
    // CONFIG COLLECTION
    // ---------------------------------------------------------
    match /config/global {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    match /config/branding {
      allow read: if true; // Public for live event mode
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------
    // CONNECTION TEST
    // ---------------------------------------------------------
    match /test_connection/status {
      allow read: if true;
    }
  }
}
